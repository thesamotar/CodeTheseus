{
  "version": 2,
  "name": "codereuse-ai",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "env": {
    "HUGGINGFACE_API_TOKEN": "@huggingface_api_token"
  },
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 300
    }
  }
}